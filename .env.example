# Copy this file to .env and fill in the values you need.
# Never commit .env. The .gitignore excludes it; verify before pushing.

# ---------------------------------------------------------------------------
# Required for content generation (Step 1)
# ---------------------------------------------------------------------------

# Anthropic API key for Claude. Get one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Default model for content generation. Recommended: claude-opus-4-7 (or current
# Opus). Don't downgrade to Haiku — see CLAUDE.md "Integration notes" for why.
ANTHROPIC_MODEL=claude-opus-4-7


# ---------------------------------------------------------------------------
# Required for image generation (Step 2)
# ---------------------------------------------------------------------------

# Google API key for Gemini. Get one at https://aistudio.google.com/app/apikey.
GOOGLE_API_KEY=


# ---------------------------------------------------------------------------
# Required for publishing (Step 5)
# ---------------------------------------------------------------------------

# Buffer access token. Generate at https://buffer.com/developers/api.
BUFFER_ACCESS_TOKEN=

# Profile ID of the Instagram Business account in Buffer.
BUFFER_PROFILE_ID=


# ---------------------------------------------------------------------------
# Required for metrics (Step 6)
# ---------------------------------------------------------------------------

# Long-lived Meta Graph API token with instagram_basic, instagram_manage_insights,
# pages_show_list, business_management permissions.
META_GRAPH_TOKEN=

# Instagram Business account ID (the numeric IG user ID, not the handle).
META_IG_USER_ID=

# Meta Graph API version. Update when Meta deprecates the current one.
META_GRAPH_VERSION=v19.0


# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# Set to 'production' before publishing to Buffer. The push-to-buffer.ts step
# refuses to run unless this is 'production' — protects against publishing
# from a dev environment.
NODE_ENV=development

# Port for the Fastify review UI. Default 3000.
REVIEW_PORT=3000

# Path to the SQLite database file. Default data/pipeline.db.
DB_PATH=data/pipeline.db
